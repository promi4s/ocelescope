{
  "name": "@ocelescope/log-overview",
  "type": "module",
  "version": "0.0.0",
  "description": "A tool for inspecting OCELs",
  "author": "Görkem-Emre Öztürk <goerkem.oeztuerk@rwth-aachen.de>",
  "license": "MIT",
  "homepage": "https://www.ocelescope.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/promi4s/ocelescope.git"
  },
  "bugs": {
    "url": "https://github.com/promi4s/ocelescope/issues"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch ./src",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@mantine/core": "catalog:",
    "@ocelescope/api-base": "workspace:*",
    "@ocelescope/core": "workspace:*",
    "@marko19907/string-to-color": "*",
    "@ocelescope/resources": "workspace:*",
    "dayjs": "catalog:",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@tsdown/css": "catalog:",
    "@types/css-modules": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
