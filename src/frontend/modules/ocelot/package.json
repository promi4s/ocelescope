{
  "name": "@ocelescope/ocelot",
  "type": "module",
  "version": "0.0.0",
  "description": "A module for inspections of OCELs",
  "author": "Görkem-Emre Öztürk <goerkem.oeztuerk@rwth-aachen.de>",
  "license": "MIT",
  "homepage": "https://www.ocelescope.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/promi4s/ocelescope.git"
  },
  "bugs": {
    "url": "https://github.com/promi4s/ocelescope/issues"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json",
    "./styles.css": "./dist/style.css"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch ./src",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@dagrejs/dagre": "catalog:",
    "@mantine/core": "catalog:",
    "@mantine/hooks": "catalog:",
    "@ocelescope/api-base": "workspace:*",
    "@ocelescope/core": "workspace:*",
    "@tanstack/react-query": "catalog:",
    "@xyflow/react": "catalog:",
    "dayjs": "catalog:",
    "elkjs": "catalog:",
    "file-saver": "catalog:",
    "html-to-image": "catalog:",
    "lucide-react": "catalog:",
    "mantine-datatable": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "@mantine/charts": "catalog:",
    "recharts": "catalog:"
  },
  "devDependencies": {
    "@tsdown/css": "catalog:",
    "@types/css-modules": "catalog:",
    "@types/file-saver": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",

    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
