{
  "name": "@ocelescope/resources",
  "type": "module",
  "version": "0.0.0",
  "description": "Ocelescope resources: helpers and UI components for rendering and exporting data.",
  "author": "Görkem-Emre Öztürk <goerkem.oeztuerk@rwth-aachen.de>",
  "license": "MIT",
  "homepage": "https://www.ocelescope.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/promi4s/ocelescope.git"
  },
  "bugs": {
    "url": "git+https://github.com/promi4s/ocelescope.git"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "release": "bumpp && pnpm publish",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@hpcc-js/wasm-graphviz": "catalog:",
    "@mantine/core": "catalog:",
    "@ocelescope/api-base": "workspace:*",
    "cytoscape": "catalog:",
    "dayjs": "catalog:",
    "file-saver": "catalog:",
    "lodash": "catalog:",
    "lucide-react": "catalog:",
    "mantine-datatable": "catalog:",
    "next": "catalog:",
    "react": "catalog:",
    "react-cytoscapejs": "catalog:",
    "react-dom": "catalog:",
    "react-plotly.js": "catalog:",
    "react-zoom-pan-pinch": "catalog:",
    "@floating-ui/react": "catalog:"
  },
  "devDependencies": {
    "@types/file-saver": "catalog:",
    "@types/lodash": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-cytoscapejs": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-plotly.js": "catalog:",
    "bumpp": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
