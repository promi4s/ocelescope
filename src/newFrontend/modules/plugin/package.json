  "peerDependencies": {
    "@apidevtools/json-schema-ref-parser": "catalog:",
    "@mantine/carousel": "catalog:",
    "@mantine/core": "catalog:",
    "@mantine/hooks": "catalog:",
    "@ocelescope/api-base": "workspace:*",
    "@ocelescope/core": "workspace:*",
    "@ocelescope/resources": "workspace:*",
    "@rjsf/core": "catalog:",
    "@rjsf/mantine": "catalog:",
    "@rjsf/utils": "catalog:",
    "@rjsf/validator-ajv8": "catalog:",
    "@tanstack/react-query": "catalog:",
    "embla-carousel": "catalog:",
    "embla-carousel-react": "catalog:",
    "flat": "catalog:",
    "json-schema-traverse": "catalog:",
    "lucide-react": "catalog:",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "catalog:",
    "uniqolor": "catalog:"
  },
  "devDependencies": {
    "@apidevtools/json-schema-ref-parser": "catalog:",
    "@ocelescope/merge-css-plugin": "workspace:*",
    "@rjsf/mantine": "catalog:",
    "@tsconfig/strictest": "^2.0.8",
    "@types/file-saver": "catalog:",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "flat": "catalog:",
    "json-schema-traverse": "catalog:",
    "tsdown": "^0.18.1",
    "typescript": "^5.9.3"
  }
}
