{
  "name": "ocelescope-workspace",
  "private": "true",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "init:backend": "uv sync --all-packages",
    "init:frontend": "pnpm i && pnpm run build:frontend",
    "init": "pnpm run init:backend && pnpm run init:frontend",
    "build:frontend": "pnpm -r --filter \"!@ocelescope/app\" run build",
    "lint:frontend": "biome check --write",
    "lint:backend": "uv run ruff check ./src/",
    "lint": "pnpm run lint:backend && pnpm run lint:frontend",
    "format:frontend": "biome format .",
    "format:backend": "uv run ruff format ./src/",
    "format": "pnpm run format:frontend && pnpm run format:backend",
    "api:generate": "uv run python src/backend/generate_openapi.py src/frontend/packages/api/base",
    "api:build": "pnpm -r --filter \"@ocelescope/api-base...\" run build",
    "api:sync": "pnpm run api:generate && pnpm run api:build",
    "dev:docs": "uv sync --group docs && uv run mkdocs serve --livereload",
    "dev:deps": "pnpm -r --parallel --filter \"!@ocelescope/app\" run dev",
    "dev:frontend": "pnpm -r --parallel --filter \"@ocelescope/app\" run dev",
    "dev:backend": "uv run ocelescope-backend --reload --reload-dir src/backend/ --env-file src/backend/.env",
    "dev:app": "pnpm run dev:backend & pnpm run dev:frontend",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build --watch",
    "docker:prod": "docker compose -f docker-compose.yml up --build",
    "docker:down": "docker compose down",
    "notebook": "uv run --with jupyterlab --with jupyter-ruff jupyter lab notebooks/"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.2",
    "@tsconfig/strictest": "catalog:",
    "orval": "catalog:"
  }
}
